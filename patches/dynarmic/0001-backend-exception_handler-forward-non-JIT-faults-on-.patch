From 274661eb75da0d5be300603ac7a62f2f8b02e451 Mon Sep 17 00:00:00 2001
From: lonycell <lonycell@gmail.com>
Date: Sun, 21 Jun 2026 23:45:24 +0900
Subject: [PATCH] backend/exception_handler: forward non-JIT faults on macOS

On macOS the JIT installs a task-level Mach exception port that intercepts
every EXC_BAD_ACCESS, including faults from non-JIT host code on protected
guest memory. Add SetNonJitFaultFallback so such faults are routed to the
host's own memory-protection handler instead of aborting.
---
 src/dynarmic/backend/exception_handler.h      |  9 ++
 .../backend/exception_handler_macos.cpp       | 85 +++++++++++++------
 2 files changed, 66 insertions(+), 28 deletions(-)

diff --git a/src/dynarmic/backend/exception_handler.h b/src/dynarmic/backend/exception_handler.h
index ed5c41c7..2e4e5d91 100644
--- a/src/dynarmic/backend/exception_handler.h
+++ b/src/dynarmic/backend/exception_handler.h
@@ -69,4 +69,13 @@ private:
     std::unique_ptr<Impl> impl;
 };
 
+// Register a process-wide fallback that is invoked when an EXC_BAD_ACCESS occurs at an address
+// that is not inside any registered JIT code block (currently macOS only). The callback receives
+// the faulting address and whether the access was a write, and should return true if it resolved
+// the fault (the faulting instruction is then retried). This lets the host's own memory-protection
+// fault handling (write-watch / page recovery) keep working even though dynarmic installs a
+// task-level Mach exception port that otherwise intercepts every EXC_BAD_ACCESS. A no-op on
+// platforms where the host signal handler still receives these faults directly.
+void SetNonJitFaultFallback(std::function<bool(void* fault_address, bool is_write)> callback);
+
 }  // namespace Dynarmic::Backend
diff --git a/src/dynarmic/backend/exception_handler_macos.cpp b/src/dynarmic/backend/exception_handler_macos.cpp
index bac8d9c9..f511c6b0 100644
--- a/src/dynarmic/backend/exception_handler_macos.cpp
+++ b/src/dynarmic/backend/exception_handler_macos.cpp
@@ -50,6 +50,10 @@ namespace Dynarmic::Backend {
 
 namespace {
 
+// Process-wide fallback for EXC_BAD_ACCESS faults that are not inside any JIT code block.
+// Set by Dynarmic::Backend::SetNonJitFaultFallback (see exception_handler.h).
+std::function<bool(void*, bool)> g_non_jit_fault_fallback;
+
 struct CodeBlockInfo {
     u64 code_begin, code_end;
     std::function<FakeCall(u64)> cb;
@@ -65,7 +69,7 @@ public:
     MachHandler();
     ~MachHandler();
 
-    kern_return_t HandleRequest(dynarmic_thread_state_t* thread_state);
+    kern_return_t HandleRequest(dynarmic_thread_state_t* thread_state, u64 fault_address, bool is_write);
 
     void AddCodeBlock(CodeBlockInfo info);
     void RemoveCodeBlock(u64 rip);
@@ -130,40 +134,54 @@ void MachHandler::MessagePump() {
     }
 }
 
-#if defined(MCL_ARCHITECTURE_X86_64)
-kern_return_t MachHandler::HandleRequest(x86_thread_state64_t* ts) {
-    std::lock_guard<std::mutex> guard(code_block_infos_mutex);
+// Invoked when the fault rip/pc is not inside any JIT code block. Tries the host fault fallback
+// (write-watch / page recovery) and returns true if the fault was resolved.
+static bool TryNonJitFallback(u64 fault_address, bool is_write) {
+    return g_non_jit_fault_fallback && g_non_jit_fault_fallback(mcl::bit_cast<void*>(fault_address), is_write);
+}
 
-    const auto iter = FindCodeBlockInfo(ts->__rip);
-    if (iter == code_block_infos.end()) {
-        fmt::print(stderr, "Unhandled EXC_BAD_ACCESS at rip {:#016x}\n", ts->__rip);
-        return KERN_FAILURE;
+#if defined(MCL_ARCHITECTURE_X86_64)
+kern_return_t MachHandler::HandleRequest(x86_thread_state64_t* ts, u64 fault_address, bool is_write) {
+    {
+        std::lock_guard<std::mutex> guard(code_block_infos_mutex);
+        const auto iter = FindCodeBlockInfo(ts->__rip);
+        if (iter != code_block_infos.end()) {
+            FakeCall fc = iter->cb(ts->__rip);
+
+            ts->__rsp -= sizeof(u64);
+            *mcl::bit_cast<u64*>(ts->__rsp) = fc.ret_rip;
+            ts->__rip = fc.call_rip;
+
+            return KERN_SUCCESS;
+        }
     }
 
-    FakeCall fc = iter->cb(ts->__rip);
+    if (TryNonJitFallback(fault_address, is_write))
+        return KERN_SUCCESS;
 
-    ts->__rsp -= sizeof(u64);
-    *mcl::bit_cast<u64*>(ts->__rsp) = fc.ret_rip;
-    ts->__rip = fc.call_rip;
-
-    return KERN_SUCCESS;
+    fmt::print(stderr, "Unhandled EXC_BAD_ACCESS at rip {:#016x} (fault {:#016x})\n", ts->__rip, fault_address);
+    return KERN_FAILURE;
 }
 #elif defined(MCL_ARCHITECTURE_ARM64)
-kern_return_t MachHandler::HandleRequest(arm_thread_state64_t* ts) {
-    std::lock_guard<std::mutex> guard(code_block_infos_mutex);
+kern_return_t MachHandler::HandleRequest(arm_thread_state64_t* ts, u64 fault_address, bool is_write) {
+    {
+        std::lock_guard<std::mutex> guard(code_block_infos_mutex);
+        const auto iter = FindCodeBlockInfo(ts->__pc);
+        if (iter != code_block_infos.end()) {
+            FakeCall fc = iter->cb(ts->__pc);
 
-    const auto iter = FindCodeBlockInfo(ts->__pc);
-    if (iter == code_block_infos.end()) {
-        fmt::print(stderr, "Unhandled EXC_BAD_ACCESS at pc {:#016x}\n", ts->__pc);
-        return KERN_FAILURE;
-    }
+            // TODO: Sign with ptrauth_sign_unauthenticated if pointer authentication is enabled.
+            ts->__pc = fc.call_pc;
 
-    FakeCall fc = iter->cb(ts->__pc);
+            return KERN_SUCCESS;
+        }
+    }
 
-    // TODO: Sign with ptrauth_sign_unauthenticated if pointer authentication is enabled.
-    ts->__pc = fc.call_pc;
+    if (TryNonJitFallback(fault_address, is_write))
+        return KERN_SUCCESS;
 
-    return KERN_SUCCESS;
+    fmt::print(stderr, "Unhandled EXC_BAD_ACCESS at pc {:#016x} (fault {:#016x})\n", ts->__pc, fault_address);
+    return KERN_FAILURE;
 }
 #endif
 
@@ -209,8 +227,8 @@ mig_external kern_return_t catch_mach_exception_raise_state_identity(mach_port_t
 mig_external kern_return_t catch_mach_exception_raise_state(
     mach_port_t /*exception_port*/,
     exception_type_t exception,
-    const mach_exception_data_t /*code*/,  // code[0] is as per kern_return.h, code[1] is rip.
-    mach_msg_type_number_t /*codeCnt*/,
+    const mach_exception_data_t code,  // code[0] is as per kern_return.h, code[1] is the fault address.
+    mach_msg_type_number_t codeCnt,
     int* flavor,
     const thread_state_t old_state,
     mach_msg_type_number_t old_stateCnt,
@@ -233,7 +251,14 @@ mig_external kern_return_t catch_mach_exception_raise_state(
     dynarmic_thread_state_t ts;
     std::memcpy(&ts, old_state, sizeof(ts));
 
-    kern_return_t ret = mach_handler->HandleRequest(&ts);
+    // For EXC_BAD_ACCESS, code[0] is the kern_return kind and code[1] is the faulting address.
+    // We can't recover the precise hardware read/write bit here (the THREAD_STATE flavor does not
+    // carry the page-fault error code), so approximate: a protection failure is almost always a
+    // write to a read-only write-watch page, while an invalid address is a (recoverable) read.
+    const u64 fault_address = (codeCnt >= 2) ? static_cast<u64>(code[1]) : 0;
+    const bool is_write = (codeCnt >= 1) && (code[0] == KERN_PROTECTION_FAILURE);
+
+    kern_return_t ret = mach_handler->HandleRequest(&ts, fault_address, is_write);
 
     std::memcpy(new_state, &ts, sizeof(ts));
     *new_stateCnt = THREAD_STATE_COUNT;
@@ -290,4 +315,8 @@ void ExceptionHandler::SetFastmemCallback(std::function<FakeCall(u64)> cb) {
     impl->SetCallback(cb);
 }
 
+void SetNonJitFaultFallback(std::function<bool(void*, bool)> callback) {
+    g_non_jit_fault_fallback = std::move(callback);
+}
+
 }  // namespace Dynarmic::Backend
